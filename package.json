{
  "name": "angular-test",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "serve": "ng serve",
    "serveHttps": "ng serve --host 0.0.0.0 --port 4400 --ssl true --ssl-key ./10.0.0.204-key.pem --ssl-cert ./10.0.0.204.pem",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "buildcap": "npm run build && npx cap sync",
    "update:capacitor": "npm install @capacitor-community/file-opener@latest @capacitor/android@latest @capacitor/angular@latest @capacitor/barcode-scanner@latest @capacitor/browser@latest @capacitor/camera@latest @capacitor/device@latest @capacitor/filesystem@latest @capacitor/splash-screen@latest @capacitor/cli@latest @capacitor/core@latest @zxing/browser@latest @zxing/library@latest @zxing/ngx-scanner@latest --force",
    "update:testlibrary": "npm install ngx-test-library"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.3",
    "@angular/cdk": "^21.2.2",
    "@angular/common": "^21.2.3",
    "@angular/compiler": "^21.2.3",
    "@angular/core": "^21.2.3",
    "@angular/forms": "^21.2.3",
    "@angular/material": "^21.2.2",
    "@angular/platform-browser": "^21.2.3",
    "@angular/platform-browser-dynamic": "^21.2.3",
    "@angular/router": "^21.2.3",
    "@capacitor-community/file-opener": "^8.0.0",
    "@capacitor/android": "^8.2.0",
    "@capacitor/angular": "^2.0.3",
    "@capacitor/barcode-scanner": "^3.0.2",
    "@capacitor/browser": "^8.0.2",
    "@capacitor/camera": "^8.0.2",
    "@capacitor/device": "^8.0.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/splash-screen": "^8.0.1",
    "@ionic/pwa-elements": "^3.2.2",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "@zxing/ngx-scanner": "^21.0.0",
    "file-saver": "^2.0.5",
    "jetifier": "^2.0.0",
    "ngx-image-cropper": "^7.0.2",
    "ngx-test-library": "file:TestLibrary/dist/package.tar.gz",
    "ngx-webcam": "^0.4.1",
    "rxjs": "~7.8.1",
    "tslib": "^2.6.1",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.2",
    "@angular/cli": "~21.2.2",
    "@angular/compiler-cli": "^21.2.3",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@types/file-saver": "^2.0.5",
    "@types/jasmine": "~4.3.5",
    "@types/node": "^20.4.5",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.2",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.3"
  }
}
